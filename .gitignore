# Cross-cutting ignores. Service-specific patterns live in backend/.gitignore
# and frontend/.gitignore.

# OS
.DS_Store
Thumbs.db

# Editors / IDEs
.vs/
.vscode/
.idea/
.cursor/
.windsurf/
*.swp
*.swo

# Claude Code workspace: config per-dev ignorada, salvo el tooling inhouse del
# proyecto (agents = subagentes; skills = procedimientos; rules = reglas
# path-scoped; workflows = orquestaciones multi-agente). La higiene de IA
# (em-dash, atribución) es user-level, no del repo.
.claude/*
!.claude/agents/
!.claude/skills/
!.claude/rules/
!.claude/workflows/

# Playwright MCP scratch (snapshots, console logs from interactive debugging)
.playwright-mcp/

# Env files (secrets)
.env
.env.local
.env.*.local
!.env.example

# Docker local overrides
docker-compose.override.yml

# Dokploy state
.dokploy/

# Logs / misc
*.log
*.bak
*.tmp
