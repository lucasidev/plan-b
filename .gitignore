# Cross-cutting ignores. Service-specific patterns live in backend/.gitignore
# and frontend/.gitignore.

# OS
.DS_Store
Thumbs.db

# Editors / IDEs
.vs/
.vscode/
.idea/
.cursor/
.windsurf/
*.swp
*.swo

# Claude Code workspace: config per-dev ignorada, salvo lo compartido inhouse
# (settings.json = hooks; agents = subagentes; skills = procedimientos;
# rules = reglas path-scoped; workflows = orquestaciones multi-agente). Ver
# docs/operations/claude-workflow.md.
.claude/*
!.claude/settings.json
!.claude/agents/
!.claude/skills/
!.claude/rules/
!.claude/workflows/

# Playwright MCP scratch (snapshots, console logs from interactive debugging)
.playwright-mcp/

# Env files (secrets)
.env
.env.local
.env.*.local
!.env.example

# Docker local overrides
docker-compose.override.yml

# Dokploy state
.dokploy/

# Logs / misc
*.log
*.bak
*.tmp
