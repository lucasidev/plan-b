{
  "$schema": "https://www.react.doctor/schema.json",
  "ignore": {
    "rules": [
      "deslop/unused-file",
      "deslop/unused-dev-dependency",
      "react-doctor/no-tiny-text",
      "react-doctor/no-wide-letter-spacing"
    ],
    "overrides": [
      {
        "files": [
          "src/features/onboarding/components/welcome-screen.tsx",
          "src/features/onboarding/components/done-screen.tsx"
        ],
        "rules": ["react-doctor/jsx-no-jsx-as-prop"]
      },
      {
        "files": ["src/features/onboarding/components/career-form.tsx"],
        "rules": ["react-doctor/no-derived-state", "react-doctor/no-event-handler"]
      },
      {
        "files": ["src/features/deactivate-account/components/deactivate-account-button.tsx"],
        "rules": ["react-doctor/prefer-use-effect-event"]
      },
      {
        "files": ["src/features/planificar/components/*.tsx"],
        "rules": ["react-doctor/no-inline-exhaustive-style"]
      },
      {
        "files": ["src/features/planificar/components/planificar-tabs.tsx"],
        "rules": ["react-doctor/nextjs-no-use-search-params-without-suspense"]
      },
      {
        "files": ["src/features/my-profile/components/profile-avatar.tsx"],
        "rules": ["react-doctor/prefer-tag-over-role"]
      },
      {
        "files": [
          "src/features/landing/components/*.tsx",
          "src/features/forgot-password/components/flow-steps.tsx"
        ],
        "rules": ["react-doctor/no-inline-exhaustive-style"]
      },
      {
        "files": ["src/features/teacher-claim/components/teacher-claim-card.tsx"],
        "rules": ["react-doctor/control-has-associated-label"]
      }
    ]
  }
}
