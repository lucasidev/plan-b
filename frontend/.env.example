# planb frontend — example .env (DOCUMENTATION ONLY)
#
# The real frontend/.env.local is generated by scripts/create-env.ts on
# 'just setup'. This file documents the variables used and serves as a reference.
#
# Two scopes (validated by src/lib/env.ts):
#   - Build-time / client-exposed: NEXT_PUBLIC_* — inlined by Next.js at build,
#     validated when the module is imported. Misconfig breaks `bun run build`.
#   - Runtime / server-only: validated lazily on first call via serverEnv().
#     Build doesn't need them; server routes that touch them fail fast in prod.

# ── Build-time / client-exposed ──────────────────────────────
# Where the backend API lives. Used by lib/api-client.ts.
NEXT_PUBLIC_API_URL=http://localhost:5000

# ── Runtime / server-only ────────────────────────────────────
# Iron-session signing key. Must be ≥32 bytes. Auto-generated by create-env.ts.
SESSION_SECRET=<32-byte-url-base64>

# Same value as the backend's JWT__Secret in the root .env. The frontend
# verifies the planb_session JWT cookie issued by the backend (HS256
# symmetric key). Auto-mirrored by create-env.ts so dev never has to
# copy-paste between the two .env files.
JWT_SECRET=<48-byte-url-base64>
