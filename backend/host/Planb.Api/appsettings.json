{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Wolverine": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "ConnectionStrings": {
    "Planb": "",
    "PlanbWolverine": ""
  },
  "JWT": {
    "Issuer": "planb",
    "Audience": "planb",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "Moderation": {
    "AutoHideThreshold": 3
  },
  "AllowedHosts": "*"
}
