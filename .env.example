# planb — example .env (DOCUMENTATION ONLY)
#
# The real .env is generated by scripts/create-env.ts on first 'just setup'.
# This file documents the variables used and serves as a reference.
#
# Convention (see ADR-0035): only secrets and host-dynamic values live here.
# Non-secret tunables (JWT issuer/audience/timings, embeddings model) live in
# appsettings.json. Dev-only overrides (SMTP host/auth/from, verification link)
# live in appsettings.Development.json. Each value has exactly one home.

# ── Secrets (auto-generated, gitignored in real .env) ────────
POSTGRES_PASSWORD=<18-byte-url-base64>
REDIS_PASSWORD=<18-byte-url-base64>
JWT__Secret=<48-byte-url-base64>
SESSION_SECRET=<32-byte-url-base64>

# ── Ports (auto-detected by scripts/ensure-infra.ts) ─────────
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# ── Backend (ASP.NET Core) ───────────────────────────────────
# '__' separates nested config keys.
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000

# Computed from POSTGRES_PASSWORD + POSTGRES_HOST_PORT by ensure-infra.ts.
ConnectionStrings__Planb=Host=localhost;Port=5432;Database=planb;Username=planb;Password=...
ConnectionStrings__PlanbWolverine=<same-as-above>
# Computed from REDIS_PASSWORD + REDIS_HOST_PORT by ensure-infra.ts. ADR-0034.
# StackExchange.Redis configuration string format.
ConnectionStrings__Redis=localhost:6379,password=...

# Mailpit SMTP port is host-dynamic (rewritten by ensure-infra.ts when 1025 is busy);
# the rest of the SMTP settings (Host, UseSsl, FromEmail, FromName) live in
# appsettings.Development.json so they don't appear duplicated here.
Smtp__Port=1025
