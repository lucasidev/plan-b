# planb — example .env (DOCUMENTATION ONLY)
#
# The real .env is generated by scripts/create-env.ts on first 'just setup'.
# This file documents the variables used and serves as a reference.
#
# Ports are rewritten dynamically by scripts/ensure-infra.ts at each 'just infra-up'
# if the default is busy.

# ── Secrets (auto-generated) ────────────────────────────────
POSTGRES_PASSWORD=<18-byte-url-base64>
JWT__Secret=<48-byte-url-base64>
SESSION_SECRET=<32-byte-url-base64>

# ── Ports (auto-detected) ───────────────────────────────────
POSTGRES_HOST_PORT=5432
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ── Backend (ASP.NET Core) ──────────────────────────────────
# '__' separates nested config keys.
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000

# Computed from POSTGRES_PASSWORD + POSTGRES_HOST_PORT by ensure-infra.ts.
ConnectionStrings__Planb=Host=localhost;Port=5432;Database=planb;Username=planb;Password=...
ConnectionStrings__PlanbWolverine=<same-as-above>

JWT__Issuer=planb
JWT__Audience=planb
JWT__AccessTokenMinutes=15
JWT__RefreshTokenDays=30

# Moderation (ADR-0010)
Moderation__AutoHideThreshold=3

# SMTP — MailHog for dev
Smtp__Host=localhost
Smtp__Port=1025
Smtp__UseSsl=false
Smtp__FromEmail=noreply@planb.local
Smtp__FromName=planb

# Embeddings (ADR-0007, ADR-0013)
Embeddings__ModelName=intfloat/multilingual-e5-base
Embeddings__ModelVersion=1.0
Embeddings__Dimensions=768
